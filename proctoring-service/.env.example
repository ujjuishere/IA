# Environment Configuration Example
# Copy this to .env and adjust values as needed

# Server
APP_NAME="Proctoring Service"
APP_VERSION="0.1.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Computer Vision Models
CONFIDENCE_THRESHOLD=0.5
EMOTION_MODEL=deepface
MIN_FACE_SIZE=20

# Performance
MAX_FRAME_SIZE=1280
RESPONSE_TIMEOUT=5

# CORS - Adjust based on your frontend URL
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
